<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ProgressBar
        android:id="@+id/pbMapLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminate="true" />

    <LinearLayout
        android:id="@+id/filterPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="?android:attr/colorBackground"
        android:alpha="0.9">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter by Type:"
            android:textSize="12sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/cbMissiles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔴 Missiles"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            android:checked="true" />

        <CheckBox
            android:id="@+id/cbAircraft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🟠 Aircraft"
            android:textSize="11sp"
            android:checked="true" />

        <CheckBox
            android:id="@+id/cbEvent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🟢 Events"
            android:textSize="11sp"
            android:checked="true" />

        <CheckBox
            android:id="@+id/cbEarthquake"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🟣 Earthquakes"
            android:textSize="11sp"
            android:checked="true" />

        <CheckBox
            android:id="@+id/cbTsunami"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔵 Tsunamis"
            android:textSize="11sp"
            android:checked="true" />

    </LinearLayout>

</FrameLayout>
