<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/alert_history_24h_title"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/pbAlertsLoading"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="12dp"
            android:visibility="gone"
            android:indeterminate="true" />

        <Button
            android:id="@+id/btnClearRefreshAlerts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/alert_clear_refresh_button"
            android:textSize="11sp"
            style="?attr/materialButtonOutlinedStyle"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginEnd="8dp"
            android:minWidth="0dp"
            android:minHeight="40dp" />

        <Button
            android:id="@+id/btnRefreshAlerts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/alert_refresh_button"
            android:textSize="12sp"
            style="?attr/materialButtonOutlinedStyle"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:minWidth="0dp"
            android:minHeight="40dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvLastRefreshed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:textSize="11sp"
        android:alpha="0.6"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textSize="16sp"
        android:padding="24dp"
        android:text="@string/alert_no_alerts"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAlerts"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
