<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground">

    <!-- Shabbat mode banner -->
    <LinearLayout
        android:id="@+id/shabbatBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="10dp"
        android:visibility="gone"
        android:background="#FF1A237E">

        <TextView
            android:id="@+id/tvShabbatBanner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:gravity="center" />

    </LinearLayout>

    <!-- Top: Compact info area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <!-- Row 1: App name + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:layout_marginStart="8dp"
                android:singleLine="true"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Row 2: Two columns - Shabbat times (left) | Parasha + Dismissals (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <!-- Left: Shabbat times -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvShabbatTimesTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/shabbat_times_title"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvShabbatTimes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvSyncStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="9sp" />

            </LinearLayout>

            <!-- Right: Parasha + Dismissals -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/shabbat_parasha_label"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="1dp" />

                <TextView
                    android:id="@+id/tvShabbatParasha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/history_summary_title"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDismissalCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:layout_marginStart="4dp"
                        android:text="@string/history_no_dismissals" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Threat State Banner (WARNING/ALARM) - always visible when active -->
    <LinearLayout
        android:id="@+id/threatBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone"
        android:background="#FFFFC107">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvThreatLevel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FF000000" />

            <Button
                android:id="@+id/btnDismissThreat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/threat_dismiss"
                android:textSize="10sp"
                style="?attr/materialButtonOutlinedStyle"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:minWidth="0dp"
                android:minHeight="28dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvThreatRegions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:textColor="#FF000000" />

        <TextView
            android:id="@+id/tvThreatSince"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:alpha="0.7"
            android:layout_marginTop="2dp"
            android:textColor="#FF000000" />

    </LinearLayout>

    <!-- Bottom: Split 50/50 - Left: Active Alerts, Right: Map -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:background="?android:attr/windowBackground">

        <!-- Left: Active Alerts with buttons at top -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.5"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Top buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnPrevAlert"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_prev"
                    android:textSize="10sp"
                    style="?attr/materialButtonOutlinedStyle"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:minWidth="0dp"
                    android:minHeight="32dp"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnPausePlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏸"
                    android:textSize="12sp"
                    style="?attr/materialButtonOutlinedStyle"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:minWidth="0dp"
                    android:minHeight="32dp"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnNextAlert"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_next"
                    android:textSize="10sp"
                    style="?attr/materialButtonOutlinedStyle"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:minWidth="0dp"
                    android:minHeight="32dp" />

            </LinearLayout>

            <!-- Scrollable content -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/active_alerts_title"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filter_note_all_tabs_regions"
                        android:textSize="9sp"
                        android:alpha="0.6"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvAlertsUpdatedTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="9sp"
                        android:alpha="0.6"
                        android:layout_marginBottom="4dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvActiveAlerts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:layout_marginBottom="4dp"
                        android:text="@string/active_alerts_none" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:id="@+id/activeAlertsScrollView"
                        android:scrollbarStyle="insideInset">

                        <TextView
                            android:id="@+id/tvActiveAlertsRegions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:padding="4dp" />

                    </ScrollView>

                </LinearLayout>

            </ScrollView>

        </LinearLayout>

        <!-- Right: Map with buttons at top -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.5"
            android:orientation="vertical"
            android:visibility="gone"
            android:id="@+id/miniMapContainer"
            android:background="?android:attr/windowBackground">

            <!-- Top buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:padding="8dp">

                <ProgressBar
                    android:id="@+id/pbAlertsLoading"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"
                    android:indeterminate="true" />

                <Button
                    android:id="@+id/btnClearAlerts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/clear_button"
                    android:textSize="9sp"
                    style="?attr/materialButtonOutlinedStyle"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:minWidth="0dp"
                    android:minHeight="32dp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnRefreshAlerts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/refresh_button"
                    android:textSize="9sp"
                    style="?attr/materialButtonOutlinedStyle"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:minWidth="0dp"
                    android:minHeight="32dp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnRefetch24h"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/refetch_24h_button"
                    android:textSize="9sp"
                    style="?attr/materialButtonOutlinedStyle"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:minWidth="0dp"
                    android:minHeight="32dp" />

            </LinearLayout>

            <!-- Map -->
            <org.osmdroid.views.MapView
                android:id="@+id/miniMapView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
